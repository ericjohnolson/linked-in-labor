---
type Props = {
  author: string;
  authorTitle: string;
  authorAvatar: string;
  timestamp: string;
  likes: number;
  /** When true, renders with slightly smaller avatar for reply indentation */
  isReply?: boolean;
};

const {
  author,
  authorTitle,
  authorAvatar,
  timestamp,
  likes,
  isReply = false,
} = Astro.props;

function formatCount(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
  if (n >= 1_000) {
    if (n < 100_000) return n.toLocaleString('en-US');
    return Math.round(n / 1_000) + 'K';
  }
  return n.toLocaleString('en-US');
}

function formatTimestamp(ts: string): string {
  const date = new Date(ts);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffMins = Math.floor(diffMs / 60_000);
  const diffHours = Math.floor(diffMins / 60);
  const diffDays = Math.floor(diffHours / 24);
  const diffWeeks = Math.floor(diffDays / 7);

  if (diffMins < 60) return `${diffMins}m`;
  if (diffHours < 24) return `${diffHours}h`;
  if (diffDays < 7) return `${diffDays}d`;
  if (diffWeeks < 4) return `${diffWeeks}w`;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

const avatarSize = isReply ? 32 : 40;
---

<div class:list={["comment", { "comment--reply": isReply }]}>
  <div class="comment-avatar-wrap">
    <img
      src={authorAvatar}
      alt={author}
      class="comment-avatar"
      width={avatarSize}
      height={avatarSize}
      loading="lazy"
      style={`width: ${avatarSize}px; height: ${avatarSize}px;`}
    />
  </div>

  <div class="comment-content">
    <div class="comment-bubble">
      <div class="comment-author-row">
        <span class="author-name comment-author-name">{author}</span>
        <span class="subtitle comment-author-title">{authorTitle}</span>
      </div>
      <div class="comment-body">
        <slot />
      </div>
    </div>

    <div class="comment-actions">
      <span class="timestamp">{formatTimestamp(timestamp)}</span>
      <button class="comment-action-btn" type="button" aria-label="Like this comment">
        Like
      </button>
      <button class="comment-action-btn" type="button" aria-label="Reply to comment">
        Reply
      </button>
      {likes > 0 && (
        <span class="comment-likes">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="14" height="14" class="comment-like-icon" aria-hidden="true">
            <path fill="#378fe9" d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0Z"/>
            <path fill="#fff" d="M5.077 6.154h-.923A1.23 1.23 0 0 0 2.923 7.385v4.307a1.23 1.23 0 0 0 1.231 1.231h.923V6.154Zm5.577-2.77c0-.34-.277-.615-.616-.615H8.616A.615.615 0 0 0 8 3.385v.923H6.462a.615.615 0 0 0-.616.615v7.077h5.808V5.692c0-.34-.277-.615-.615-.615H8.923a.308.308 0 0 1 0-.616h1.116c.34 0 .615-.276.615-.615Z"/>
          </svg>
          <span class="text-secondary">{formatCount(likes)}</span>
        </span>
      )}
    </div>
  </div>
</div>

<style>
  .comment {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 4px 0;
  }

  .comment--reply {
    padding-left: 48px;
    margin-top: 4px;
  }

  .comment-avatar-wrap {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .comment-avatar {
    border-radius: 50%;
    object-fit: cover;
    background-color: var(--color-divider);
  }

  .comment-content {
    flex: 1;
    min-width: 0;
  }

  .comment-bubble {
    background-color: rgba(0, 0, 0, 0.04);
    border-radius: 8px;
    padding: 8px 12px;
  }

  .comment-author-row {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-bottom: 4px;
  }

  .comment-author-name {
    font-size: 13px;
  }

  .comment-author-title {
    font-size: 12px;
  }

  .comment-body {
    font-size: 14px;
    line-height: var(--line-height-body);
    color: var(--color-text-primary);
  }

  .comment-body :global(p) {
    margin-bottom: 4px;
  }

  .comment-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .comment-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0 0 4px;
    font-size: 12px;
  }

  .comment-action-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 12px;
    font-family: var(--font-stack);
    font-weight: 700;
    color: var(--color-text-secondary);
    padding: 0;
    transition: color 0.1s ease;
  }

  .comment-action-btn:hover {
    color: var(--color-text-primary);
    text-decoration: underline;
  }

  .comment-likes {
    display: flex;
    align-items: center;
    gap: 3px;
    margin-left: auto;
  }

  .comment-like-icon {
    border-radius: 50%;
  }
</style>
