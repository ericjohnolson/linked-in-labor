---
type Props = {
  likes: number;
  comments?: number;
  reposts: number;
};

const { likes, comments = 0, reposts } = Astro.props;

function formatCount(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
  if (n >= 1_000) {
    const k = n / 1_000;
    // Use comma format up to 99,999; use K abbreviation above
    if (n < 100_000) return n.toLocaleString('en-US');
    return k.toFixed(0) + 'K';
  }
  return n.toLocaleString('en-US');
}
---

<div class="reaction-bar">
  <div class="reaction-counts">
    <!-- Reaction emoji summary (like, celebrate, etc.) -->
    <span class="reaction-emojis" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" class="reaction-icon reaction-like-icon">
        <path fill="#378fe9" d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0Z"/>
        <path fill="#fff" d="M5.077 6.154h-.923A1.23 1.23 0 0 0 2.923 7.385v4.307a1.23 1.23 0 0 0 1.231 1.231h.923V6.154Zm5.577-2.77c0-.34-.277-.615-.616-.615H8.616A.615.615 0 0 0 8 3.385v.923H6.462a.615.615 0 0 0-.616.615v7.077h5.808V5.692c0-.34-.277-.615-.615-.615H8.923a.308.308 0 0 1 0-.616h1.116c.34 0 .615-.276.615-.615Z"/>
      </svg>
    </span>
    {likes > 0 && (
      <span class="reaction-count text-secondary">{formatCount(likes)}</span>
    )}
  </div>

  <div class="reaction-meta text-secondary">
    {comments > 0 && (
      <span>{formatCount(comments)} comment{comments !== 1 ? 's' : ''}</span>
    )}
    {reposts > 0 && (
      <span>{formatCount(reposts)} repost{reposts !== 1 ? 's' : ''}</span>
    )}
  </div>
</div>

<hr class="divider" />

<div class="reaction-actions">
  <!-- Like -->
  <button class="reaction-btn" type="button" aria-label="Like">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" focusable="false" class="reaction-btn-icon">
      <path d="M19.46 11l-3.91-3.91a7 7 0 01-1.69-2.74l-.49-1.47A2.76 2.76 0 0010.76 1 2.75 2.75 0 008 3.74v1.12a9.19 9.19 0 00.46 2.85L8.89 9H4.12A2.12 2.12 0 002 11.12a2.16 2.16 0 00.92 1.76A2.11 2.11 0 002 14.62a2.14 2.14 0 001.28 1.96A2 2 0 003 17.07a2.12 2.12 0 002.12 2.12h1.69a8.41 8.41 0 002.17-.28l1.39-.37a5.81 5.81 0 011.37-.18H12v-9.5zM21.5 12h-1a1 1 0 00-1 1v9.5h2a1 1 0 001-1V13a1 1 0 00-1-1z" fill="currentColor"/>
    </svg>
    <span>Like</span>
  </button>

  <!-- Comment -->
  <button class="reaction-btn" type="button" aria-label="Comment">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" focusable="false" class="reaction-btn-icon">
      <path d="M7 9h10v1H7zm0 4h7v1H7zm16-2a6.78 6.78 0 01-2.84 5.61L12 22v-4H6A7 7 0 016 4h5a7 7 0 016 3.32A6.87 6.87 0 0123 11zm-2 0a5 5 0 00-5-5H6a5 5 0 000 10h8v2.28L19.77 15A4.78 4.78 0 0021 11z" fill="currentColor"/>
    </svg>
    <span>Comment</span>
  </button>

  <!-- Repost -->
  <button class="reaction-btn" type="button" aria-label="Repost">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" focusable="false" class="reaction-btn-icon">
      <path d="M13.96 5H6a2 2 0 00-2 2v6h2V7h7.96v3l4-4-4-4v3zM10 19H6v-3l-4 4 4 4v-3h4a2 2 0 002-2v-3h-2v3zm8 1h-4v-1a1 1 0 00-1-1H9v2H7v-2H5l3.5-3.5L12 17h-2v2h4v-3l4 4z" fill="currentColor"/>
    </svg>
    <span>Repost</span>
  </button>

  <!-- Send / Share -->
  <button class="reaction-btn" type="button" aria-label="Send">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" focusable="false" class="reaction-btn-icon">
      <path d="M21 3L0 10l7.66 4.26L16 8l-6.26 8.34L14 24l7-21z" fill="currentColor"/>
    </svg>
    <span>Send</span>
  </button>
</div>

<style>
  .reaction-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 16px 8px;
    font-size: 12px;
    color: var(--color-text-secondary);
    min-height: 28px;
  }

  .reaction-counts {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .reaction-emojis {
    display: flex;
    align-items: center;
  }

  .reaction-like-icon {
    border-radius: 50%;
  }

  .reaction-count {
    font-size: 12px;
  }

  .reaction-meta {
    display: flex;
    gap: 8px;
    font-size: 12px;
  }

  .reaction-actions {
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 4px 16px;
  }

  .reaction-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 12px;
    background: none;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-text-secondary);
    font-size: 14px;
    font-family: var(--font-stack);
    font-weight: 600;
    transition: background-color 0.1s ease, color 0.1s ease;
  }

  .reaction-btn:hover {
    background-color: rgba(0, 0, 0, 0.06);
    color: var(--color-text-primary);
  }

  .reaction-btn-icon {
    flex-shrink: 0;
  }

  /* Override global divider to add horizontal inset within card */
  :global(.divider) {
    margin-left: 16px;
    margin-right: 16px;
  }
</style>
